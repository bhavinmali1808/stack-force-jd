# ──────────────────────────────────────────────────────────────
# TalentForce JD — Server Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Client URL (comma-separated for multiple origins)
CLIENT_URL=http://localhost:5173

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── Database ────────────────────────────────────────────────
# Development: local MongoDB
MONGODB_URI=mongodb://localhost:27017/talentforce

# Production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/talentforce?retryWrites=true&w=majority

# ── File Storage (Cloudflare R2) ────────────────────────────
# Leave empty for development (uses local disk instead)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=talentforce-resumes
R2_PUBLIC_URL=https://pub-XXXX.r2.dev

# ── Queue & Cache (Upstash Redis) ───────────────────────────
# Leave empty for development (uses in-memory SimpleQueue)
REDIS_URL=

# Production (Upstash):
# REDIS_URL=rediss://default:<pass>@<host>.upstash.io:6379

# ── AI Parsing (Google Gemini) ──────────────────────────────
GEMINI_API_KEY=

# Python Parser (optional microservice)
PYTHON_PARSER_URL=http://localhost:8000

# ── Email (optional) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Monitoring (optional) ────────────────────────────────────
SENTRY_DSN=
